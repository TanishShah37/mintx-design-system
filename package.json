{
  "name": "mintx-design-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:design-system": "turbo dev --filter=@mintx/design-system",
    "dev:docs": "turbo dev --filter=@mintx/design-system",
    "storybook": "turbo storybook --filter=@mintx/ui",
    "build:storybook": "turbo build-storybook --filter=@mintx/ui",
    "build:design-system": "turbo build --filter=@mintx/design-system",
    "build:docs": "turbo build:docs --filter=@mintx/design-system",
    "build:ui": "turbo build --filter=@mintx/ui",
    "build:all": "npm run build:storybook && npm run build:docs",
    "standardize-tokens": "node scripts/standardize-tokens.mjs"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.2",
    "@storybook/addon-interactions": "^8.6.2",
    "@storybook/addon-links": "^8.6.2",
    "@storybook/blocks": "^8.6.2",
    "@storybook/react": "^8.6.2",
    "@storybook/react-vite": "^8.6.2",
    "@storybook/test": "^8.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.2",
    "tailwindcss": "^3.4.17",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  },
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "boneyard-js": "^1.7.7"
  }
}
